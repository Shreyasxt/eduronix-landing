<script>
const supabaseClient = supabase.createClient(
  "https://mnbyvbhfkrkkmmgkedch.supabase.co",
  "sb_publishable_6Y-dqTHFSvMWoO-vcnqfiw_tvp9X3qB"
);

// College toggle
document.getElementById("college").addEventListener("change", function () {
  const otherInput = document.getElementById("otherCollege");
  if (this.value === "Other") {
    otherInput.classList.remove("hidden");
  } else {
    otherInput.classList.add("hidden");
  }
});

// ✅ PLAN TOGGLE
function togglePlan(plan) {
  const soloCard = document.getElementById("solo-card");
  const buddyCard = document.getElementById("buddy-card");
  const buddySection = document.getElementById("buddy-section");
  const perkSolo = document.getElementById("perk-solo");
  const perkBuddy = document.getElementById("perk-buddy");
  const btnText = document.getElementById("btn-text");

  if (plan === "buddy") {
    buddyCard.classList.add("plan-active");
    soloCard.classList.remove("plan-active");
    buddySection.classList.remove("hidden");
    perkSolo.classList.add("hidden");
    perkBuddy.classList.remove("hidden");
    btnText.textContent = "Find My Mentor → Secure My Slot ₹499";
  } else {
    soloCard.classList.add("plan-active");
    buddyCard.classList.remove("plan-active");
    buddySection.classList.add("hidden");
    perkSolo.classList.remove("hidden");
    perkBuddy.classList.add("hidden");
    btnText.textContent = "Find My Mentor → Secure My Slot ₹299";
  }
}

// ✅ PAYMENT FUNCTION
async function handlePayment() {
  const btn = document.getElementById("payBtn");
  const selectedPlan = document.querySelector('input[name="plan"]:checked').value;
  const isBuddy = selectedPlan === "buddy";

  const data = {
    name: document.getElementById("name").value,
    phone: document.getElementById("phone").value,
    email: document.getElementById("email").value,
    city: document.getElementById("city").value,
    college: document.getElementById("college").value === "Other"
      ? document.getElementById("otherCollege").value
      : document.getElementById("college").value,
    course: document.getElementById("course").value,
    gender: document.getElementById("gender").value,
    requirements: document.getElementById("requirements").value,
    plan: selectedPlan,
  };

  if (!data.name || !data.phone || !data.email) {
    alert("Please fill required fields");
    return;
  }

  if (!/^\d{10}$/.test(data.phone)) {
    alert("Enter valid 10-digit phone number");
    return;
  }

  // BuddyPass validation
  if (isBuddy) {
    const buddyName = document.getElementById("buddy_name").value;
    const buddyPhone = document.getElementById("buddy_phone").value;
    const buddyEmail = document.getElementById("buddy_email").value;
    if (!buddyName || !buddyPhone || !buddyEmail) {
      alert("Please fill buddy's name, phone and email");
      return;
    }
    if (!/^\d{10}$/.test(buddyPhone)) {
      alert("Enter valid 10-digit phone number for buddy");
      return;
    }
    data.buddy_name = buddyName;
    data.buddy_phone = buddyPhone;
    data.buddy_email = buddyEmail;
    data.buddy_city = document.getElementById("buddy_city").value;
  }

  btn.querySelector("span").textContent = "Redirecting...";
  btn.disabled = true;

  try {
    const { error } = await supabaseClient
      .from("booking_requests")
      .insert([{
        name: data.name,
        phone: data.phone,
        email: data.email,
        city: data.city,
        college: data.college,
        course: data.course,
        mentor_gender: data.gender,
        requirements: data.requirements,
        plan: data.plan,
        buddy_name: data.buddy_name || null,
        buddy_phone: data.buddy_phone || null,
        buddy_email: data.buddy_email || null,
        buddy_city: data.buddy_city || null,
        payment_id: "form_redirect",
        status: "pending"
      }]);

    if (error) {
      console.error("Supabase Error:", error);
      alert("Error saving data");
      btn.querySelector("span").textContent = isBuddy
        ? "Find My Mentor → Secure My Slot ₹499"
        : "Find My Mentor → Secure My Slot ₹299";
      btn.disabled = false;
      return;
    }

    // Redirect to Cashfree
    window.location.href = "https://payments.cashfree.com/forms?code=eduronix-booking";

  } catch (err) {
    console.error(err);
    alert("Something went wrong");
    btn.querySelector("span").textContent = isBuddy
      ? "Find My Mentor → Secure My Slot ₹499"
      : "Find My Mentor → Secure My Slot ₹299";
    btn.disabled = false;
  }
}
</script>
